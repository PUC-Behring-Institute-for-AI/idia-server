# IDIA Server — Environment Configuration Template
#
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.
#
# Required variables:
#   HF_TOKEN, LITELLM_MASTER_KEY, MODEL_ID, MODEL_SOURCE
#
# Optional variables (with defaults):
#   MAX_MODEL_LEN = 8192, GPU_MEMORY_UTILIZATION = 0.9
#
# Multi-model mode: set MODELS_COUNT=N and MODEL_1_ID..MODEL_N_SOURCE
#   (omit MODEL_ID/MODEL_SOURCE when using multi-model mode)
#
# See docs/ARCHITECTURE.md §5.5 and AGENTS.md §Env Var Convention.

# HuggingFace token — required for downloading gated models
HF_TOKEN=hf_xxx

# LiteLLM master admin key — used to generate virtual keys
LITELLM_MASTER_KEY=sk-litellm-admin-change-me

# ── Model Configuration ───────────────────────────────────────────────────
# Single-model mode (backward compatible):
# Short alias for the model — clients use this in the `model` field
MODEL_ID=llama-3.1-8b
# Full HuggingFace Hub identifier for the model
MODEL_SOURCE=meta-llama/Llama-3.1-8B-Instruct

# Multi-model mode (uncomment and set to use):
# MODELS_COUNT=2
# MODEL_1_ID=llama-3.1-8b
# MODEL_1_SOURCE=meta-llama/Llama-3.1-8B-Instruct
# MODEL_2_ID=qwen-2.5-14b
# MODEL_2_SOURCE=Qwen/Qwen2.5-14B-Instruct

# Maximum context length in tokens (optional, default: 8192)
MAX_MODEL_LEN=8192

# Fraction of GPU memory to reserve for weights + KV cache (optional, default: 0.9)
GPU_MEMORY_UTILIZATION=0.9

# Number of GPUs available on the node (optional, default: 1)
# Used by VRAM budget validation to ensure multi-model configs fit.
GPU_COUNT=1

# VRAM per GPU in GB (optional, default: 24.0 — matches A10G on g5.xlarge)
GPU_VRAM_GB=24.0

# Grafana admin password — required if Grafana is enabled (see §5.4)
GRAFANA_ADMIN_PASSWORD=changeme
